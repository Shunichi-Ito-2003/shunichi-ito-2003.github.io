---
const currentPath = Astro.url.pathname;
const isEn = currentPath.startsWith('/en');
const prefix = isEn ? '/en' : '';

const navLinks = [
  { href: `${prefix}/#news`,  label: 'NEWS',    match: null },
  { href: `${prefix}/#works`, label: 'WORKS',   match: null },
  { href: `${prefix}/blog`,   label: 'BLOG',    match: isEn ? '/en/blog' : '/blog' },
  { href: `${prefix}/about`,  label: 'PROFILE', match: isEn ? '/en/about' : '/about' },
  { href: `${prefix}/#contact`, label: 'CONTACT', match: null },
];

function isActive(match: string | null) {
  if (!match) return false;
  return currentPath.startsWith(match);
}

// 言語切替先URL
function switchLang(to: 'ja' | 'en') {
  if (to === 'en') {
    if (isEn) return currentPath;
    // ブログ記事（/blog/slug）は英語版なし → /en/blog へ
    if (currentPath.match(/^\/blog\/.+/)) return '/en/blog';
    return '/en' + (currentPath === '/' ? '' : currentPath);
  } else {
    if (!isEn) return currentPath;
    return currentPath.replace(/^\/en/, '') || '/';
  }
}
---

<header class="fixed top-0 left-0 right-0 z-50 bg-[var(--color-cream)]/90 backdrop-blur-sm border-b border-[var(--color-border)]">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">

    <!-- Logo -->
    <a
      href={isEn ? '/en/' : '/'}
      class="font-display text-sm tracking-[0.25em] text-[var(--color-ink)] hover:text-[var(--color-gold)] transition-colors"
    >
      ITO SHUNICHI
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`font-display text-xs tracking-[0.2em] transition-colors relative ${
            isActive(link.match)
              ? 'text-[var(--color-gold)]'
              : 'text-[var(--color-ink-muted)] hover:text-[var(--color-gold)]'
          }`}
        >
          {link.label}
          {isActive(link.match) && (
            <span class="absolute -bottom-1 left-0 right-0 h-px bg-[var(--color-gold)]" />
          )}
        </a>
      ))}

      <!-- Language switcher -->
      <div class="flex items-center gap-1 border border-[var(--color-border)] overflow-hidden">
        <a
          href={switchLang('ja')}
          class={`font-display text-xs tracking-widest px-2.5 py-1 transition-colors ${
            !isEn
              ? 'bg-[var(--color-gold)] text-white'
              : 'text-[var(--color-ink-muted)] hover:text-[var(--color-gold)]'
          }`}
        >JA</a>
        <a
          href={switchLang('en')}
          class={`font-display text-xs tracking-widest px-2.5 py-1 transition-colors ${
            isEn
              ? 'bg-[var(--color-gold)] text-white'
              : 'text-[var(--color-ink-muted)] hover:text-[var(--color-gold)]'
          }`}
        >EN</a>
      </div>
    </nav>

    <!-- Mobile menu button -->
    <button
      id="menu-btn"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="メニューを開く"
    >
      <span class="block w-5 h-px bg-[var(--color-ink)] transition-all"></span>
      <span class="block w-5 h-px bg-[var(--color-ink)] transition-all"></span>
      <span class="block w-3 h-px bg-[var(--color-ink)] transition-all"></span>
    </button>
  </div>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-[var(--color-border)] bg-[var(--color-cream)]">
    <nav class="max-w-6xl mx-auto px-6 py-6 flex flex-col gap-5">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`font-display text-xs tracking-[0.2em] transition-colors ${
            isActive(link.match)
              ? 'text-[var(--color-gold)]'
              : 'text-[var(--color-ink-muted)] hover:text-[var(--color-gold)]'
          }`}
        >
          {link.label}
        </a>
      ))}
      <!-- Mobile language switcher -->
      <div class="flex items-center gap-1 border border-[var(--color-border)] w-fit overflow-hidden">
        <a
          href={switchLang('ja')}
          class={`font-display text-xs tracking-widest px-3 py-1.5 transition-colors ${
            !isEn ? 'bg-[var(--color-gold)] text-white' : 'text-[var(--color-ink-muted)]'
          }`}
        >JA</a>
        <a
          href={switchLang('en')}
          class={`font-display text-xs tracking-widest px-3 py-1.5 transition-colors ${
            isEn ? 'bg-[var(--color-gold)] text-white' : 'text-[var(--color-ink-muted)]'
          }`}
        >EN</a>
      </div>
    </nav>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16"></div>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
  menu?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => menu.classList.add('hidden'));
  });
</script>
