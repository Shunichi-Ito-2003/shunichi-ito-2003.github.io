---
const navLinks = [
  { href: '/#news', label: 'NEWS', match: null },
  { href: '/#works', label: 'WORKS', match: null },
  { href: '/blog', label: 'BLOG', match: '/blog' },
  { href: '/about', label: 'PROFILE', match: '/about' },
  { href: '/#contact', label: 'CONTACT', match: null },
];

const currentPath = Astro.url.pathname;

function isActive(match: string | null) {
  if (!match) return false;
  return currentPath.startsWith(match);
}
---

<header class="fixed top-0 left-0 right-0 z-50 bg-[var(--color-cream)]/90 backdrop-blur-sm border-b border-[var(--color-border)]">
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">

    <!-- Logo -->
    <a
      href="/"
      class="font-display text-sm tracking-[0.25em] text-[var(--color-ink)] hover:text-[var(--color-gold)] transition-colors"
    >
      ITO SHUNICHI
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`font-display text-xs tracking-[0.2em] transition-colors relative ${
            isActive(link.match)
              ? 'text-[var(--color-gold)]'
              : 'text-[var(--color-ink-muted)] hover:text-[var(--color-gold)]'
          }`}
        >
          {link.label}
          {isActive(link.match) && (
            <span class="absolute -bottom-1 left-0 right-0 h-px bg-[var(--color-gold)]" />
          )}
        </a>
      ))}
    </nav>

    <!-- Mobile menu button -->
    <button
      id="menu-btn"
      class="md:hidden flex flex-col gap-1.5 p-2"
      aria-label="メニューを開く"
    >
      <span class="block w-5 h-px bg-[var(--color-ink)] transition-all"></span>
      <span class="block w-5 h-px bg-[var(--color-ink)] transition-all"></span>
      <span class="block w-3 h-px bg-[var(--color-ink)] transition-all"></span>
    </button>
  </div>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-[var(--color-border)] bg-[var(--color-cream)]">
    <nav class="max-w-6xl mx-auto px-6 py-6 flex flex-col gap-5">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`font-display text-xs tracking-[0.2em] transition-colors ${
            isActive(link.match)
              ? 'text-[var(--color-gold)]'
              : 'text-[var(--color-ink-muted)] hover:text-[var(--color-gold)]'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-16"></div>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
  // Close menu on link click
  menu?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => menu.classList.add('hidden'));
  });
</script>
