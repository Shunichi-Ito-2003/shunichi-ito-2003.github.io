---
import Layout from '../layouts/Layout.astro';
import { getPublishedPosts } from '../lib/posts';

const recentPosts = getPublishedPosts().slice(0, 3);

const works = [
  {
    href: '/works/shimamori',
    category: 'STAGE / ACTING',
    title: '島守のうた',
    description: '沖縄戦・最後の官選知事・島田叡を演じる。沖縄・栃木・兵庫をつなぐ巡回公演。',
    image: '/写真、画像/島守のうた/島守のうた チラシ.jpg',
    year: '2026',
  },
  {
    href: '/works/santa',
    category: 'CHARITY PROJECT',
    title: 'みんながサンタ！',
    description: '120家庭にケーキを届けるチャリティー企画。企画・運営・サンタ役として参加。',
    image: '/写真、画像/みんながサンタ/2025/劇中の一枚.jpeg',
    year: '2025',
  },
  {
    href: '/works/chiiki',
    category: 'COMMUNITY / STAGE',
    title: '地域を応援する演劇',
    description: '31名が3チームで地域の誰かを応援する演劇を上演。チーム恵比寿として脚本・出演し、まぁさん堂を応援。',
    image: '/写真、画像/地域を応援する演劇/season1　まぁさん堂/チーム恵比寿集合写真.JPG',
    year: '2026',
  },
];
---

<Layout>
  <!-- ── HERO ─────────────────────────────── -->
  <section class="min-h-[92vh] grid md:grid-cols-2 overflow-hidden">
    <!-- Left: Text -->
    <div class="relative flex flex-col justify-center px-8 md:px-16 py-20 bg-[var(--color-cream)] order-2 md:order-1 overflow-hidden">
      <!-- 背景装飾：巨大な薄いゴールド文字 -->
      <span class="absolute -left-4 top-1/2 -translate-y-1/2 font-display text-[18rem] font-bold text-[var(--color-gold)] opacity-[0.04] leading-none select-none pointer-events-none">
        IS
      </span>

      <div class="relative z-10 space-y-7 max-w-md">
        <div class="flex items-center gap-3">
          <span class="h-px w-8 bg-[var(--color-gold)]"></span>
          <span class="font-display text-xs tracking-[0.3em] text-[var(--color-gold)]">ACTOR / MEDICAL STUDENT</span>
        </div>

        <h1 class="font-display text-6xl md:text-7xl tracking-[0.05em] md:tracking-[0.1em] text-[var(--color-ink)] leading-[1.05]">
          ITO<br />SHUNICHI
        </h1>

        <p class="font-japanese text-base text-[var(--color-ink-muted)]">伊藤 駿一</p>

        <p class="font-japanese text-sm text-[var(--color-ink-muted)] leading-loose">
          「演劇は世界を平和にする」という信念のもと、<br />
          沖縄を拠点に俳優として活動する医学生。
        </p>

        <!-- ゴールドのゴール表示 -->
        <div class="border-l-2 border-[var(--color-gold)] pl-4 py-1">
          <p class="font-display text-xs tracking-[0.2em] text-[var(--color-ink-muted)] mb-0.5">GOAL</p>
          <p class="font-japanese text-sm text-[var(--color-gold-dark)] font-bold">カンヌ国際映画祭 主演男優賞</p>
        </div>

        <div class="flex flex-col sm:flex-row gap-3 pt-2">
          <a
            href="#works"
            class="px-8 py-3.5 bg-[var(--color-gold)] text-white font-display text-xs tracking-[0.2em] hover:bg-[var(--color-gold-dark)] transition-all duration-300 text-center"
          >
            WORKS
          </a>
          <a
            href="/blog"
            class="px-8 py-3.5 border border-[var(--color-border)] text-[var(--color-ink-muted)] font-display text-xs tracking-[0.2em] hover:border-[var(--color-ink)] hover:text-[var(--color-ink)] transition-all duration-300 text-center"
          >
            BLOG
          </a>
        </div>
      </div>
    </div>

    <!-- Right: Photo with gold frame -->
    <div class="relative h-[70vw] md:h-auto order-1 md:order-2 overflow-hidden">
      <img
        src="/写真、画像/my portfolio/hero.jpg"
        alt="ITO SHUNICHI"
        class="w-full h-full object-cover object-center"
      />
      <!-- ゴールドの装飾フレーム -->
      <div class="absolute inset-4 border border-[var(--color-gold)]/30 pointer-events-none hidden md:block"></div>
      <!-- 左側のグラデーション（テキスト側との接続） -->
      <div class="absolute inset-y-0 left-0 w-20 bg-gradient-to-r from-[var(--color-cream)] to-transparent hidden md:block"></div>
    </div>
  </section>

  <!-- ── ゴールドの区切りマーキー ─── -->
  <div class="bg-[var(--color-gold)] py-3 overflow-hidden">
    <div class="marquee-track flex gap-12 whitespace-nowrap">
      {Array.from({length: 8}).map(() => (
        <span class="font-display text-xs tracking-[0.3em] text-white opacity-90">
          ACTOR &nbsp;·&nbsp; MEDICAL STUDENT &nbsp;·&nbsp; OKINAWA &nbsp;·&nbsp; CANNES &nbsp;·&nbsp; 俳優 &nbsp;·&nbsp; 伊藤駿一
        </span>
      ))}
    </div>
  </div>

  <!-- ── NEWS ──────────────────────────────── -->
  <section id="news" class="fade-in py-24 px-6 bg-white">
    <div class="max-w-4xl mx-auto">
      <header class="flex items-end justify-between mb-12">
        <div>
          <p class="font-display text-xs tracking-[0.3em] text-[var(--color-gold)] mb-2">最新情報</p>
          <h2 class="font-display text-4xl md:text-5xl tracking-[0.12em] text-[var(--color-ink)]">NEWS</h2>
        </div>
      </header>

      <!-- タイムライン形式 -->
      <div class="relative pl-6 border-l-2 border-[var(--color-border)] space-y-0">
        {[
          { date: '2026.03.15', cat: 'PROJECT', title: '地域を応援する演劇 Season 1 完走。まぁさん堂（南風原）を応援' },
          { date: '2026.02.08', cat: 'STAGE', title: '舞台『島守のうた』神戸公演。浦崎純役として出演' },
          { date: '2025.12', cat: 'CHARITY', title: 'クリスマスチャリティー企画「みんながサンタ！」120家庭へのケーキ配達完了' },
        ].map((item) => (
          <article class="relative py-7 group">
            <!-- ゴールドの点 -->
            <div class="absolute -left-[1.45rem] top-9 w-3 h-3 rounded-full border-2 border-[var(--color-gold)] bg-white group-hover:bg-[var(--color-gold)] transition-colors"></div>
            <time class="font-display text-xs tracking-widest text-[var(--color-ink-muted)] block mb-1">{item.date}</time>
            <span class="font-display text-xs tracking-widest text-[var(--color-gold)] block mb-2">{item.cat}</span>
            <h3 class="font-japanese text-[var(--color-ink)] group-hover:text-[var(--color-gold-dark)] transition-colors leading-relaxed">
              {item.title}
            </h3>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── WORKS（ダーク背景） ────────────────── -->
  <section id="works" class="fade-in py-24 px-6 bg-[#1C1C1C]">
    <div class="max-w-6xl mx-auto">
      <header class="flex items-end justify-between mb-12">
        <div>
          <p class="font-display text-xs tracking-[0.3em] text-[var(--color-gold)] mb-2">活動アーカイブ</p>
          <h2 class="font-display text-4xl md:text-5xl tracking-[0.12em] text-white">WORKS</h2>
        </div>
        <a href="/works" class="hidden md:flex items-center gap-2 font-display text-xs tracking-[0.2em] text-white/40 hover:text-[var(--color-gold)] transition-colors">
          ALL WORKS →
        </a>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-white/10">
        {works.map((work, i) => (
          <a href={work.href} class="group relative overflow-hidden aspect-[3/4] block">
            <img
              src={work.image}
              alt={work.title}
              class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-700"
            />
            <!-- オーバーレイ -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>
            <!-- ゴールドの番号 -->
            <div class="absolute top-5 right-5 font-display text-3xl text-white/20">{String(i+1).padStart(2,'0')}</div>
            <!-- テキスト -->
            <div class="absolute bottom-0 left-0 right-0 p-6">
              <span class="font-display text-xs tracking-[0.2em] text-[var(--color-gold)] block mb-2">{work.category}</span>
              <h3 class="font-japanese text-xl font-bold text-white mb-2 leading-snug">{work.title}</h3>
              <p class="font-japanese text-xs text-white/60 leading-relaxed line-clamp-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                {work.description}
              </p>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-8 md:hidden text-center">
        <a href="/works" class="font-display text-xs tracking-[0.2em] text-white/40 hover:text-[var(--color-gold)] transition-colors">
          ALL WORKS →
        </a>
      </div>
    </div>
  </section>

  <!-- ── MONOLOGUE ──────────────────────────── -->
  <section id="monologue" class="fade-in py-24 px-6 bg-[var(--color-cream)]">
    <div class="max-w-6xl mx-auto">
      <header class="flex items-end justify-between mb-12">
        <div>
          <p class="font-display text-xs tracking-[0.3em] text-[var(--color-gold)] mb-2">思考の庭</p>
          <h2 class="font-display text-4xl md:text-5xl tracking-[0.12em] text-[var(--color-ink)]">MONOLOGUE</h2>
        </div>
        <a href="/blog" class="hidden md:flex items-center gap-2 font-display text-xs tracking-[0.2em] text-[var(--color-ink-muted)] hover:text-[var(--color-gold)] transition-colors">
          ALL ARTICLES →
        </a>
      </header>

      {recentPosts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {recentPosts.map((post, i) => (
            <a
              href={`/blog/${post.slug}`}
              class="group flex flex-col bg-white border border-[var(--color-border)] hover:border-[var(--color-gold)] transition-all duration-300 overflow-hidden"
            >
              <!-- ゴールドのアクセントバー -->
              <div class="h-1 bg-[var(--color-gold)] opacity-0 group-hover:opacity-100 transition-opacity"></div>
              <div class="p-6 flex flex-col flex-grow">
                <div class="flex items-center gap-3 mb-4">
                  <span class="font-display text-xs tracking-widest text-[var(--color-ink-muted)]">{post.date}</span>
                  <span class="h-px flex-grow bg-[var(--color-border)]"></span>
                  <span class="font-display text-xs text-[var(--color-gold)]">{String(i+1).padStart(2,'0')}</span>
                </div>
                <h3 class="font-japanese font-bold text-[var(--color-ink)] group-hover:text-[var(--color-gold-dark)] leading-relaxed mb-3 line-clamp-3 flex-grow">
                  {post.title}
                </h3>
                <p class="font-japanese text-sm text-[var(--color-ink-muted)] leading-relaxed line-clamp-2">
                  {post.excerpt}
                </p>
                <div class="mt-5 pt-4 border-t border-[var(--color-border)] font-display text-xs tracking-widest text-[var(--color-gold)]">
                  READ MORE →
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="font-japanese text-[var(--color-ink-muted)]">記事はまだありません</p>
        </div>
      )}

      <div class="mt-8 md:hidden">
        <a href="/blog" class="font-display text-xs tracking-[0.2em] text-[var(--color-ink-muted)] hover:text-[var(--color-gold)] transition-colors">
          ALL ARTICLES →
        </a>
      </div>
    </div>
  </section>

  <!-- ── CONTACT ────────────────────────────── -->
  <section id="contact" class="fade-in py-24 px-6 bg-[var(--color-ink)]">
    <div class="max-w-2xl mx-auto text-center space-y-8">
      <div>
        <p class="font-display text-xs tracking-[0.3em] text-[var(--color-gold)] mb-3">お問い合わせ</p>
        <h2 class="font-display text-4xl md:text-5xl tracking-[0.12em] text-white">CONTACT</h2>
      </div>
      <div class="h-px w-12 bg-[var(--color-gold)] mx-auto"></div>
      <p class="font-japanese text-white/60 leading-loose">
        出演依頼、脚本執筆のご相談、その他お問い合わせは<br class="hidden md:block" />
        以下のメールアドレスよりお願いいたします。
      </p>
      <a
        href="mailto:changeupandshake@gmail.com"
        class="inline-block px-10 py-4 border border-[var(--color-gold)] text-[var(--color-gold)] font-display tracking-[0.2em] text-sm hover:bg-[var(--color-gold)] hover:text-white transition-all duration-300"
      >
        SEND EMAIL
      </a>
    </div>
  </section>
</Layout>

<style>
  /* マーキーアニメーション */
  .marquee-track {
    animation: marquee 30s linear infinite;
    width: max-content;
  }
  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
</style>
