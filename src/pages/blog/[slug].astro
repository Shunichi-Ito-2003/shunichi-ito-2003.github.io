---
import Layout from '../../layouts/Layout.astro';
import { getAllPosts, getPostBySlug } from '../../lib/posts';
import { marked } from 'marked';

export async function getStaticPaths() {
  const posts = getAllPosts().filter((p) => p.published);
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = getPostBySlug(slug as string);

if (!post) {
  return Astro.redirect('/blog');
}

const htmlContent = await marked(post.content, { breaks: true });
---

<Layout title={post.title} description={post.excerpt}>
  <article class="max-w-2xl mx-auto px-6 py-16">
    <!-- Back link -->
    <a
      href="/blog"
      class="inline-flex items-center gap-2 font-display text-xs tracking-[0.2em] text-[var(--color-ink-muted)] hover:text-[var(--color-gold)] transition-colors mb-12"
    >
      ← BLOG
    </a>

    <!-- Article header -->
    <header class="mb-12 pb-8 border-b border-[var(--color-border)]">
      <div class="flex items-center gap-4 mb-4">
        <time class="font-display text-xs tracking-widest text-[var(--color-ink-muted)]">{post.date}</time>
        {post.category && (
          <span class="font-display text-xs tracking-widest text-[var(--color-gold)]">{post.category}</span>
        )}
      </div>
      <h1 class="font-japanese text-2xl md:text-3xl font-bold text-[var(--color-ink)] leading-relaxed">
        {post.title}
      </h1>
    </header>

    <!-- Article body -->
    <div class="prose-article" set:html={htmlContent} />

    <!-- Footer -->
    <footer class="mt-16 pt-8 border-t border-[var(--color-border)]">
      {post.note_url && (
        <a
          href={post.note_url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 font-display text-xs tracking-[0.2em] text-[var(--color-gold)] hover:text-[var(--color-gold-dark)] transition-colors mb-6 block"
        >
          note でも読む →
        </a>
      )}
      <a
        href="/blog"
        class="inline-flex items-center gap-2 font-display text-xs tracking-[0.2em] text-[var(--color-ink-muted)] hover:text-[var(--color-gold)] transition-colors"
      >
        ← 記事一覧に戻る
      </a>
    </footer>
  </article>
</Layout>
