---
import Layout from '../../../layouts/Layout.astro';
import { getPostsByKeyword } from '../../../lib/posts';

const relatedPosts = getPostsByKeyword('地域を応援する演劇').slice(0, 8);

const teams = [
  {
    name: 'Team Ebisu',
    theme: 'Prosperous Business',
    members: '16 members',
    target: 'Maasan-do',
    targetDesc: 'A community diner in Haebaru Town, Okinawa. Founded in 2008, approaching its 20th year.',
    date: '2026.03.15',
    status: 'Completed',
    me: true,
  },
  {
    name: 'Team Daikokuten',
    theme: 'Happiness / Fortune / Longevity',
    members: '7 members',
    target: 'Nursery School',
    targetDesc: 'A nursery school run by a friend of an 01ENTERTAINMENT member. Production title: "Nursery School War."',
    date: '2026.04.05',
    status: 'Upcoming',
    me: false,
  },
  {
    name: 'Team Benzaiten',
    theme: 'Health / Medicine / Longevity',
    members: '8 members',
    target: "Hiroki's Gyoza",
    targetDesc: 'A gyoza restaurant in Okinawa that offers disability discounts, creating a space where disabled and non-disabled people connect.',
    date: '2026.05.03',
    status: 'Upcoming',
    me: false,
  },
];

const highlights = [
  { date: '2025.12', text: 'The question "Why doesn\'t theater reach more of society?" sparks the concept of "Theater to Support the Community."' },
  { date: '2026.01.04', text: '31 members divided into 3 teams. Shunichi joins Team Ebisu (16 members).' },
  { date: '2026.01.08', text: 'Supported venue decided: Team Ebisu will support "Maasan-do" diner.' },
  { date: '2026.01', text: 'Research interview conducted with Maasan-do owner Shigenori and his wife.' },
  { date: '2026.01–02', text: 'Scriptwriting begins. Crafting a story that leverages the individuality of 15 cast members.' },
  { date: '2026.02.18', text: 'Script complete, casting confirmed. Roles assigned to all 15 actors.' },
  { date: '2026.03.07', text: 'One week before opening. Zero ticket sales — confronting reality with relentless outreach.' },
  { date: '2026.03.15', text: 'Opening night. Season 1 complete — delivering "a time to cheer for someone\'s hard work."' },
];
---

<Layout
  title="Theater to Support the Community"
  description="A theater × social impact project by 01ENTERTAINMENT. 31 members in 3 teams stage monthly productions to support local businesses. Shunichi Ito served as playwright and actor for Team Ebisu, supporting Maasan-do in Haebaru."
>
  <!-- Hero -->
  <section class="relative h-[70vh] overflow-hidden">
    <img src="/写真、画像/地域を応援する演劇/season1　まぁさん堂/チーム恵比寿集合写真.JPG" alt="Theater to Support the Community" class="w-full h-full object-cover object-center" />
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 p-8 md:p-16 max-w-4xl">
      <a href="/en/works" class="font-display text-xs tracking-[0.2em] text-white/50 hover:text-[var(--color-gold)] transition-colors mb-6 block">← Works</a>
      <span class="font-display text-xs tracking-[0.3em] text-[var(--color-gold)] block mb-3">COMMUNITY / STAGE · 2026</span>
      <h1 class="font-display text-3xl md:text-5xl text-white leading-tight mb-4">Theater to Support<br />the Community</h1>
      <p class="text-sm text-white/70 leading-relaxed">"Theater for someone" — starting from Okinawa</p>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-6 py-16 space-y-20">

    <!-- Overview -->
    <section class="fade-in space-y-6">
      <div>
        <p class="font-display text-xs tracking-[0.3em] text-[var(--color-gold)] mb-3">OVERVIEW</p>
        <h2 class="font-display text-2xl tracking-widest text-[var(--color-ink)] mb-6">About the project</h2>
      </div>
      <div class="space-y-4 text-sm text-[var(--color-ink-muted)] leading-loose text-justify">
        <p>
          "Why doesn't theater reach more of society?" — the answer was simple: <strong class="text-[var(--color-ink)]">"Because there's not enough theater made for someone else."</strong>
        </p>
        <p>
          Born from this question, "Theater to Support the Community" divides 31 actors from 01ENTERTAINMENT into 3 teams. Each team stages one production per month and <strong class="text-[var(--color-ink)]">donates 25% of ticket revenue to their chosen local business.</strong>
        </p>
        <p>
          Each team chooses, researches, interviews, and creates a story about their own supported business. Different teams mean different stories, different audiences — cascading outward until theater becomes woven into the community.
        </p>
      </div>
    </section>

    <!-- Teams -->
    <section class="fade-in">
      <p class="font-display text-xs tracking-[0.3em] text-[var(--color-gold)] mb-3">3 TEAMS</p>
      <h2 class="font-display text-2xl tracking-widest text-[var(--color-ink)] mb-8">Teams & supported venues</h2>
      <div class="space-y-4">
        {teams.map((team) => (
          <div class={`border ${team.me ? 'border-[var(--color-gold)] bg-[var(--color-cream)]' : 'border-[var(--color-border)] bg-white'} p-6`}>
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div class="space-y-1">
                <div class="flex items-center gap-3 flex-wrap">
                  <h3 class="font-display text-sm tracking-widest text-[var(--color-ink)]">{team.name}</h3>
                  {team.me && <span class="font-display text-xs tracking-widest text-white bg-[var(--color-gold)] px-2 py-0.5">MY TEAM</span>}
                  <span class={`font-display text-xs tracking-widest px-2 py-0.5 ${team.status === 'Completed' ? 'text-[var(--color-ink-muted)] border border-[var(--color-border)]' : 'text-[var(--color-gold)] border border-[var(--color-gold)]'}`}>
                    {team.status}
                  </span>
                </div>
                <p class="font-display text-xs tracking-widest text-[var(--color-ink-muted)]">{team.members} · {team.theme}</p>
              </div>
              <time class="font-display text-xs tracking-widest text-[var(--color-ink-muted)]">{team.date}</time>
            </div>
            <div class="mt-4 pt-4 border-t border-[var(--color-border)]">
              <p class="font-display text-xs tracking-widest text-[var(--color-gold)] mb-1">SUPPORTING</p>
              <p class="font-display text-sm font-bold text-[var(--color-ink)] mb-1">{team.target}</p>
              <p class="text-xs text-[var(--color-ink-muted)] leading-relaxed">{team.targetDesc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- My role -->
    <section class="fade-in border-l-2 border-[var(--color-gold)] pl-8 space-y-4">
      <p class="font-display text-xs tracking-[0.3em] text-[var(--color-gold)]">MY ROLE</p>
      <h2 class="font-display text-xl text-[var(--color-ink)]">Team Ebisu — supporting Maasan-do</h2>
      <div class="space-y-4 text-sm text-[var(--color-ink-muted)] leading-loose text-justify">
        <p>
          I belong to Team Ebisu, a team of 16. For Season 1, we chose to support <strong class="text-[var(--color-ink)]">Maasan-do</strong>, a community diner in Haebaru Town that has been running since 2008. One of our team members, Reemi, has parents who run the diner. We chose them because we wanted to start by supporting someone close to us.
        </p>
        <p>
          Through research and interviews, I wrote a script capturing the story of how the owner Shigenori built the interior nearly by himself, the relationships deep enough that he knows a regular's order just by seeing their face, and the journey of a couple who raised their children with the help of their regulars.
        </p>
        <p>
          Not just "performing" — but "writing," "researching," and "delivering." Being involved in every stage of this project was an experience that taught me, in my body, how theater can live within society.
        </p>
      </div>
    </section>

    <!-- Flyer -->
    <section class="fade-in">
      <p class="font-display text-xs tracking-[0.3em] text-[var(--color-gold)] mb-3">FLYER</p>
      <h2 class="font-display text-2xl tracking-widests text-[var(--color-ink)] mb-6">Season 1 flyer</h2>
      <div class="grid grid-cols-2 gap-4 max-w-lg">
        <img src="/写真、画像/地域を応援する演劇/season1　まぁさん堂/フライヤー表.JPG" alt="Flyer — Front" class="w-full border border-[var(--color-border)]" />
        <img src="/写真、画像/地域を応援する演劇/season1　まぁさん堂/フライヤー裏.JPG" alt="Flyer — Back" class="w-full border border-[var(--color-border)]" />
      </div>
    </section>

    <!-- Timeline -->
    <section class="fade-in">
      <p class="font-display text-xs tracking-[0.3em] text-[var(--color-gold)] mb-3">TIMELINE</p>
      <h2 class="font-display text-2xl tracking-widest text-[var(--color-ink)] mb-8">Record</h2>
      <div class="relative pl-6 border-l-2 border-[var(--color-border)] space-y-0">
        {highlights.map((h) => (
          <div class="relative py-5 group">
            <div class="absolute -left-[1.45rem] top-7 w-3 h-3 rounded-full border-2 border-[var(--color-gold)] bg-white group-hover:bg-[var(--color-gold)] transition-colors"></div>
            <time class="font-display text-xs tracking-widest text-[var(--color-ink-muted)] block mb-1">{h.date}</time>
            <p class="text-sm text-[var(--color-ink)] leading-relaxed">{h.text}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Related posts -->
    {relatedPosts.length > 0 && (
      <section class="fade-in">
        <p class="font-display text-xs tracking-[0.3em] text-[var(--color-gold)] mb-3">DOCUMENT</p>
        <h2 class="font-display text-2xl tracking-widest text-[var(--color-ink)] mb-4">Production journal (29-part series)</h2>
        <p class="text-xs text-[var(--color-ink-muted)] mb-8">* Written in Japanese</p>
        <div class="divide-y divide-[var(--color-border)]">
          {relatedPosts.map((post) => (
            <a href={`/blog/${post.slug}`} class="group flex gap-6 py-5 hover:bg-[var(--color-cream)] px-2 -mx-2 transition-colors">
              <time class="font-display text-xs tracking-widest text-[var(--color-ink-muted)] shrink-0 pt-1 w-24">{post.date}</time>
              <h3 class="font-japanese text-[var(--color-ink)] group-hover:text-[var(--color-gold-dark)] transition-colors leading-relaxed line-clamp-2">{post.title}</h3>
              <span class="shrink-0 self-center font-display text-xs text-[var(--color-gold)] opacity-0 group-hover:opacity-100 transition-opacity">→</span>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</Layout>
